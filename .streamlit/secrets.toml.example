# Copy this file to .streamlit/secrets.toml for local use,
# or paste the contents into the Streamlit Cloud Secrets editor.
# .streamlit/secrets.toml is gitignored — never commit real credentials.

[informatica]
BASE_URL      = "https://dm-us.informaticacloud.com"
BASE_API_URL  = "https://idmc-api.dm-us.informaticacloud.com"
IICS_USERNAME = "your-username@example.com"
IICS_PASSWORD = "your-password"
